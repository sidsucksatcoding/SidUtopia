# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create a project at https://console.cloud.google.com
# Go to APIs & Services > Credentials > Create OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Must exactly match one of the redirect URIs registered in Google Cloud Console
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── AI (Groq) ─────────────────────────────────────────────────────────────────
# Free API key at https://console.groq.com
GROQ_API_KEY=your-groq-api-key

# ── AI (Gemini — optional fallback) ──────────────────────────────────────────
# Free API key at https://aistudio.google.com
GEMINI_API_KEY=your-gemini-api-key
