# ══════════════════════════════════════════════════════════════════════════════
# .env.example  —  Template for your secret configuration values
# ══════════════════════════════════════════════════════════════════════════════
#
# What is a .env file?
#   A plain text file that holds "secret keys" your app needs.
#   Think of it like a keychain — the app reads these values at startup so you
#   never have to hard-code a password inside your source code.
#
# How to use this file:
#   1. Copy it:    cp .env.example .env
#   2. Open .env and replace every "your-..." placeholder with your real values.
#   3. NEVER commit the real .env to Git — it is listed in .gitignore already.
#
# Lines starting with # are comments — the app ignores them.
# ══════════════════════════════════════════════════════════════════════════════


# ── Google OAuth ──────────────────────────────────────────────────────────────
# These two values let your app log in to Google on your behalf.
#
# How to get them:
#   1. Go to https://console.cloud.google.com
#   2. Create a project (or pick an existing one)
#   3. APIs & Services  →  Credentials  →  Create  →  OAuth 2.0 Client ID
#   4. Application type: Web application
#   5. Add http://localhost:3000/auth/callback  under "Authorised redirect URIs"
#   6. Copy the Client ID and Client Secret shown on the next screen

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# This URL must EXACTLY match what you entered in Google Cloud Console above.
# On Render (production) set this to your live URL, e.g.:
#   https://sidutopia.onrender.com/auth/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback


# ── Server ────────────────────────────────────────────────────────────────────
# The port number the server listens on.
# 3000 is a common choice for development.  Render sets this automatically in
# production, so you usually don't need to change it there.
PORT=3000


# ── AI Chat (Groq) ────────────────────────────────────────────────────────────
# Groq runs the AI chat feature.  It's free to sign up.
# Get your key at https://console.groq.com  →  API Keys  →  Create API Key
GROQ_API_KEY=your-groq-api-key


# ── SMS Notifications (Twilio) ────────────────────────────────────────────────
# Twilio sends the "Send Summary" text message to your phone.
#
# How to get these:
#   1. Sign up at https://www.twilio.com  (free trial is enough)
#   2. Your Account SID and Auth Token are on the Console Dashboard page
#   3. TWILIO_FROM is the Twilio phone number assigned to your account
#      (looks like +15551234567)
#   4. TWILIO_TO is the real phone number(s) to send the SMS to
#      Multiple numbers: separate with commas  →  +15550000001,+15550000002

TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM=+15551234567
TWILIO_TO=+15550000001
